<%- include("partials/head", { pageTitle, message }) %>
<div class="app-header simple">
  <a class="left ui-back-link is-light" href="/plugin.php?id=xigua_hb&ac=my&high=4"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7"/></svg><span>返回</span></a>
  <div class="title">我的同城信息</div>
</div>

<div class="search-shell"><span style="display:inline-flex;width:.82rem;height:.82rem;vertical-align:-.12rem;margin-right:.18rem;color:#a4afbc;"><svg viewBox="0 0 24 24" aria-hidden="true" style="width:100%;height:100%;stroke:currentColor;stroke-width:1.9;fill:none;stroke-linecap:round;stroke-linejoin:round;"><circle cx="11" cy="11" r="5.5"/><path d="m16 16 3.6 3.6"/></svg></span>请输入关键词</div>

<div class="seg-tabs cols-4" style="border-radius:0;margin:.55rem 0 0;">
  <a href="/plugin.php?id=xigua_hb&ac=my_posts&tab=active&high=4" class="<%= statusTab === 'active' ? 'active' : '' %>">显示中(<%= data.posts.filter((p) => p.status === 'active').length %>)</a>
  <a href="/plugin.php?id=xigua_hb&ac=my_posts&tab=pending&high=4" class="<%= statusTab === 'pending' ? 'active' : '' %>">待审核(0)</a>
  <a href="/plugin.php?id=xigua_hb&ac=my_posts&tab=ended&high=4" class="<%= statusTab === 'ended' ? 'active' : '' %>">已过期(<%= data.posts.filter((p) => p.status !== 'active').length %>)</a>
  <a href="/plugin.php?id=xigua_hb&ac=my_posts&tab=top&high=4" class="<%= statusTab === 'top' ? 'active' : '' %>">置顶(0)</a>
</div>

<% const filtered = statusTab === 'ended' ? data.posts.filter((p) => p.status !== 'active') : statusTab === 'active' ? data.posts.filter((p) => p.status === 'active') : []; %>
<% if (filtered.length) { %>
  <div class="simple-list">
    <% filtered.forEach((post) => { %>
      <div class="item">
        <a href="/plugin.php?id=xigua_hb&ac=view&pubid=<%= post.id %>" style="display:block;text-decoration:none;color:inherit;">
          <div class="item-title"><%= post.title %></div>
        </a>
        <div class="item-desc"><%= post.summary %></div>
        <div class="item-footer">
          <span><%= post.location %></span>
          <span><%= post.created_at %></span>
        </div>
      </div>
    <% }) %>
  </div>
<% } else { %>
  <div class="empty-state">
    <div class="icon"><svg viewBox="0 0 24 24" aria-hidden="true" style="width:2rem;height:2rem;stroke:currentColor;stroke-width:1.55;fill:none;stroke-linecap:round;stroke-linejoin:round;"><path d="M8 4.8h6.5L18.2 8v11.2H8A2.2 2.2 0 0 1 5.8 17V7A2.2 2.2 0 0 1 8 4.8Z"/><path d="M14.5 4.8V8h3.7"/><path d="M9.2 12.2h5.6"/><path d="M9.2 15.2h4.1"/></svg></div>
    <div style="margin-top:.7rem;">没有更多了</div>
  </div>
<% } %>

<%- include("partials/tabbar", { currentTab: "mine" }) %>
