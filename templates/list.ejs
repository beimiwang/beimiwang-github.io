    <% }) %>
  </div>

  <% if (!allPosts.length) { %>
    <div class="job-empty">当前分类暂无内容</div>
  <% } %>
</div>

<script>
  (function () {
    const overlay = document.getElementById("filterOverlay");
    const mask = document.getElementById("filterMask");
    const toggles = Array.from(document.querySelectorAll(".js-filter-toggle"));
    const panels = Array.from(document.querySelectorAll(".filter-panel"));
    const areaGroups = {
      <% areaGroups.forEach((group, index) => { %>
        "<%= group.name %>": <%- JSON.stringify(group.children) %><%= index < areaGroups.length - 1 ? ',' : '' %>
      <% }) %>
    };
    const tagGroups = {
      <% tagGroups.forEach((group, index) => { %>
        "<%= group.name %>": <%- JSON.stringify(group.children) %><%= index < tagGroups.length - 1 ? ',' : '' %>
      <% }) %>
    };
    let currentPanel = "";

    function closePanels() {
      currentPanel = "";
      overlay.classList.remove("is-open");
      mask.classList.remove("is-open");
      panels.forEach((panel) => panel.classList.remove("is-open"));
      toggles.forEach((toggle) => toggle.classList.remove("active"));
    }

    function openPanel(panelName, toggle) {
      if (currentPanel === panelName) {
        closePanels();
        return;
      }
      currentPanel = panelName;
      overlay.classList.add("is-open");
      mask.classList.add("is-open");
      panels.forEach((panel) => panel.classList.toggle("is-open", panel.dataset.panel === panelName));
      toggles.forEach((item) => item.classList.toggle("active", item === toggle));
    }

    toggles.forEach((toggle) => {
      toggle.addEventListener("click", function () {
        openPanel(toggle.dataset.panel, toggle);
      });
    });

    mask.addEventListener("click", closePanels);

    document.querySelectorAll(".js-area-group").forEach((link) => {
      link.addEventListener("click", function () {
        const group = link.dataset.group;
        const rightColumn = document.querySelector(".area-column.right");
        if (!rightColumn || !areaGroups[group]) return;
        document.querySelectorAll(".js-area-group").forEach((item) => item.classList.toggle("active", item === link));
        rightColumn.innerHTML = areaGroups[group].map(function (areaName) {
          const href = areaName === "全部"
            ? "<%= buildListUrl({ area: '' }) %>"
            : "<%= buildListUrl({ area: '__AREA__' }) %>".replace("__AREA__", encodeURIComponent(areaName));
          const active = <%- JSON.stringify(currentArea) %> === areaName || (!<%- JSON.stringify(currentArea) %> && areaName === "全部");
          return '<a href="' + href + '"' + (active ? ' class="active"' : '') + '>' + areaName + '</a>';
        }).join("");
      });
    });

    document.querySelectorAll(".js-tag-group").forEach((link) => {
      link.addEventListener("click", function () {
        const group = link.dataset.group;
        const rightColumn = document.querySelector(".tag-column.right");
        if (!rightColumn || !tagGroups[group]) return;
        document.querySelectorAll(".js-tag-group").forEach((item) => item.classList.toggle("active", item === link));
        rightColumn.innerHTML = tagGroups[group].map(function (tagName) {
          const href = tagName === "全部"
            ? "<%= buildListUrl({ tag: '' }) %>"
            : "<%= buildListUrl({ tag: '__TAG__' }) %>".replace("__TAG__", encodeURIComponent(tagName));
          const active = <%- JSON.stringify(currentTag) %> === tagName || (!<%- JSON.stringify(currentTag) %> && tagName === "全部");
          return '<a href="' + href + '"' + (active ? ' class="active"' : '') + '>' + tagName + '</a>';
        }).join("");
      });
    });
  })();
</script>

<%- include("partials/tabbar", { currentTab }) %>
<% } %>
