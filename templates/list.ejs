  </div>
</div>
<%- include("partials/tabbar", { currentTab }) %>
<% } else { %>
<div class="list-app">
  <div class="list-header">
    <a class="ui-back-link is-light" href="/plugin.php?id=xigua_hb&mobile=2&high=0"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7"/></svg><span>返回</span></a>
    <div class="title"><%= data.category ? data.category.name : "分类" %></div>
    <a href="/plugin.php?id=xigua_hb&ac=pub&high=2" style="text-align:right;">发布</a>
  </div>

  <% if (banner && banner.image_url) { %>
    <% if (banner.target_url) { %>
      <a class="list-banner has-image" href="<%= banner.target_url %>">
        <img src="<%= banner.image_url %>" alt="<%= data.category ? data.category.name : '分类' %> banner">
      </a>
    <% } else { %>
      <div class="list-banner has-image">
        <img src="<%= banner.image_url %>" alt="<%= data.category ? data.category.name : '分类' %> banner">
      </div>
    <% } %>
  <% } else { %>
    <div class="list-banner text-banner">
      <div class="line1"><%= bannerText %></div>
    </div>
  <% } %>

  <div class="list-filters">
    <div class="list-filter-top">
      <a href="javascript:;" class="js-filter-toggle" data-panel="area-panel"><%= currentArea || "地区" %></a>
      <a href="javascript:;" class="js-filter-toggle" data-panel="tag-panel"><%= currentTag || (data.category ? data.category.name : "分类") %></a>
      <a href="javascript:;" class="js-filter-toggle" data-panel="sort-panel"><%= selectedSort.label %></a>
    </div>
    <div class="filter-overlay" id="filterOverlay">
      <div class="filter-panel area-panel" data-panel="area-panel">
        <div class="area-column left">
          <% areaGroups.forEach((group) => { %>
            <a
              href="javascript:;"
              class="js-area-group <%= selectedAreaGroup.name === group.name ? 'active' : '' %>"
              data-group="<%= group.name %>"
            ><%= group.name %></a>
          <% }) %>
        </div>
        <div class="area-column right">
          <% selectedAreaGroup.children.forEach((areaName) => { %>
            <a href="<%= buildListUrl({ area: areaName === '全部' ? '' : areaName }) %>" class="<%= (!currentArea && areaName === '全部') || currentArea === areaName ? 'active' : '' %>"><%= areaName %></a>
          <% }) %>
        </div>
      </div>
      <div class="filter-panel tag-panel" data-panel="tag-panel">
        <div class="tag-column left">
          <% tagGroups.forEach((group) => { %>
            <a
              href="javascript:;"
              class="js-tag-group <%= selectedTagGroup.name === group.name ? 'active' : '' %>"
              data-group="<%= group.name %>"
            ><%= group.name %></a>
          <% }) %>
        </div>
        <div class="tag-column right">
          <% selectedTagGroup.children.forEach((tagName) => { %>
            <a href="<%= buildListUrl({ tag: tagName === '全部' ? '' : tagName }) %>" class="<%= (!currentTag && tagName === '全部') || currentTag === tagName ? 'active' : '' %>"><%= tagName %></a>
          <% }) %>
        </div>
      </div>
      <div class="filter-panel simple-panel" data-panel="sort-panel">
        <% ((data.filterOptions && data.filterOptions.sorts) || []).forEach((sortItem) => { %>
          <a href="<%= buildListUrl({ sort: sortItem.value }) %>" class="<%= currentSort === sortItem.value ? 'active' : '' %>"><%= sortItem.label %></a>
        <% }) %>
      </div>
    </div>
    <div class="list-filter-tabs">
      <% quickTags.forEach((tag, index) => { %>
        <a href="<%= buildListUrl({ tag: index === 0 ? '' : tag }) %>" class="<%= (index === 0 && !currentTag) || currentTag === tag ? 'active' : '' %>"><%= tag %></a>
      <% }) %>
    </div>
  </div>
  <div class="filter-mask" id="filterMask"></div>

  <div class="job-list">
    <% allPosts.forEach((post, index) => { %>
      <a href="/plugin.php?id=xigua_hb&ac=view&pubid=<%= post.id %>" class="job-card <%= index === 0 ? 'featured' : '' %>">
        <div class="job-head">
          <div class="job-badges">
            <span class="job-badge green"><%= postType(post) %></span>
            <% if (index === 0) { %><span class="job-badge top">置顶</span><% } %>
            <% (post.tags || []).slice(0, 1).forEach((tag) => { %>
              <span class="job-badge outline"><%= tag %></span>
            <% }) %>
          </div>
          <div class="job-meta">来自<%= post.city || post.location || "本地" %>&nbsp;&nbsp;<%= formatRelative(post.created_at) %></div>
        </div>
        <div class="job-desc"><%= post.content || post.summary %></div>
