  }
  .list-filter-tabs a {
    flex: none;
    min-width: 3.1rem;
    height: 1.35rem;
    line-height: 1.35rem;
    padding: 0 .6rem;
    background: #f1f1f1;
    color: #555;
    border-radius: 999px;
    text-align: center;
    font-size: .66rem;
