          <div class="ride-desc"><%= post.ride_description || post.summary || post.content %></div>
          </a>
          <div class="ride-card-footer">
            <div class="ride-meta">
              <span><%= formatRelative(post.created_at) %></span>
              <span>◉ <%= post.views %></span>
