  .job-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
    margin-bottom: .42rem;
  }
  .job-badges {
    display: flex;
    align-items: center;
    gap: .18rem;
    min-width: 0;
    flex-wrap: wrap;
  }
  .job-badge {
    display: inline-block;
    height: 1rem;
    line-height: 1rem;
    border-radius: .22rem;
