</style>

<% if (isRideCategory) { %>
<div class="ride-app">
  <div class="ride-header">
    <a class="ui-back-link is-light" href="/plugin.php?id=xigua_hb&mobile=2&high=0"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7"/></svg><span>返回</span></a>
    <div class="title"><%= data.category ? data.category.name : "顺风车" %></div>
    <a href="/plugin.php?id=xigua_hb&ac=pub&high=2" style="text-align:right;">发布</a>
  </div>

  <% if (banner && banner.image_url) { %>
    <% if (banner.target_url) { %>
      <a class="ride-banner" href="<%= banner.target_url %>"><img src="<%= banner.image_url %>" alt="顺风车 banner"></a>
    <% } else { %>
      <div class="ride-banner"><img src="<%= banner.image_url %>" alt="顺风车 banner"></div>
    <% } %>
  <% } else { %>
    <div class="ride-banner"><div class="line1"><%= bannerText %></div></div>
  <% } %>

  <div class="ride-tabs">
    <% (rideData.rideTabs || ["全部", "车找人", "长期线路车", "人找车"]).forEach((tab) => { %>
      <% const active = (!rideData.rideType && tab === "全部") || rideData.rideType === tab; %>
      <a class="ride-tab <%= active ? 'active' : '' %>" href="<%= buildRideUrl({ ride_type: tab === '全部' ? '' : tab, route_chip: '', origin: rideData.originKeyword || '', destination: rideData.destinationKeyword || '' }) %>">
        <img src="<%= data.category && data.category.icon ? data.category.icon : 'https://lzlm1.oss-cn-beijing.aliyuncs.com/xigua/20251110/wx6911d54baf82b.png' %>" alt="<%= tab %>">
        <div><%= tab %></div>
        <% if (active) { %><div class="ride-tab-strip"></div><% } %>
      </a>
    <% }) %>
  </div>

  <div class="ride-routes">
    <% (rideData.routeChips || []).forEach((chip, index) => { %>
      <a class="ride-route-chip <%= (!rideData.routeChip && index > 2) ? 'is-muted' : '' %>" href="<%= buildRideUrl({ route_chip: chip, origin: '', destination: '' }) %>"><%= chip.replace('⇌', '⇌') %></a>
    <% }) %>
  </div>

  <form class="ride-search" method="get" action="/plugin.php">
    <input type="hidden" name="id" value="xigua_hb">
    <input type="hidden" name="ac" value="cat">
    <input type="hidden" name="cat_id" value="<%= data.category ? data.category.id : 1038 %>">
    <% if (rideData.rideType) { %><input type="hidden" name="ride_type" value="<%= rideData.rideType %>"><% } %>
    <% if (rideData.routeChip) { %><input type="hidden" name="route_chip" value="<%= rideData.routeChip %>"><% } %>
    <input type="text" name="origin" value="<%= rideData.originKeyword || '' %>" placeholder="出发地搜索">
    <div class="ride-switch">⇄</div>
    <input type="text" name="destination" value="<%= rideData.destinationKeyword || '' %>" placeholder="目的地搜索">
    <button type="submit">搜索</button>
  </form>

  <div class="ride-disclaimer">📢 免责声明：本平台不对任何人提供任何形式担保，所有信息仅供参考，不承担任何民事及法律责任，用户使用本平台即视为同意。</div>

  <div class="ride-list-head">
    <span>顺风车信息</span>
    <a href="<%= buildRideUrl({ sort: currentSort === 'default' ? 'views' : 'default' }) %>"><%= selectedSort.label %></a>
  </div>

  <div class="ride-cards">
    <% if (allPosts.length) { %>
      <% allPosts.forEach((post) => { %>
        <div class="ride-card">
          <a href="/plugin.php?id=xigua_hb&ac=view&pubid=<%= post.id %>" class="ride-card-link">
          <div class="ride-card-top">
            <span class="ride-badge"><%= post.ride_type || "车找人" %></span>
            <span class="ride-route"><%= `${post.ride_origin || "出发地"} → ${post.ride_destination || "目的地"}` %></span>
