<%- include("partials/head", { pageTitle, message }) %>
<style>
  :root {
    --mine-bg: #f5f5f7;
    --mine-surface: rgba(255, 255, 255, .88);
    --mine-card: #ffffff;
    --mine-text: #111827;
    --mine-subtle: #6b7280;
    --mine-line: rgba(15, 23, 42, .08);
    --mine-shadow: 0 .12rem .55rem rgba(15, 23, 42, .06);
    --mine-radius: .9rem;
    --mine-accent: #35c96d;
  }

  .mine-page {
    min-height: 100vh;
    padding: .7rem .6rem 4.8rem;
    background:
      radial-gradient(circle at top left, rgba(52, 200, 111, .1), transparent 28%),
      linear-gradient(180deg, #fbfbfc, var(--mine-bg));
  }

  .mine-card {
    background: var(--mine-card);
    border: 1px solid rgba(255,255,255,.7);
    border-radius: var(--mine-radius);
    box-shadow: var(--mine-shadow);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .mine-hero {
    padding: .88rem .88rem .82rem;
    background:
      linear-gradient(180deg, rgba(255,255,255,.2), rgba(255,255,255,.06)),
      linear-gradient(180deg, #35c96d, #35c96d);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .mine-hero::before,
  .mine-hero::after {
    content: "";
    position: absolute;
    background: rgba(255,255,255,.12);
    border-radius: 999px;
    pointer-events: none;
  }

  .mine-hero::before {
    width: 3rem;
    height: .9rem;
    right: -.4rem;
    top: 1rem;
    transform: rotate(-48deg);
  }

  .mine-hero::after {
    width: .9rem;
    height: .9rem;
    left: .45rem;
    top: .3rem;
  }

  .mine-topbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .86rem;
    position: relative;
    z-index: 1;
  }

  .mine-user {
    display: flex;
    align-items: center;
    gap: .92rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  .mine-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,.88);
    object-fit: cover;
    flex: 0 0 auto;
    background: rgba(255,255,255,.14);
  }

  .mine-avatar-link {
    display: inline-flex;
    border-radius: 50%;
    text-decoration: none;
    flex: 0 0 auto;
  }

  .mine-copy {
    min-width: 0;
  }

  .mine-name {
    font-size: .96rem;
    line-height: 1.12rem;
    font-weight: 650;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mine-subactions {
    display: flex;
    align-items: center;
    gap: .44rem;
    margin-top: .4rem;
    flex-wrap: wrap;
  }

  .mine-verify-row {
    display: flex;
    align-items: center;
    gap: .34rem;
    margin-top: .42rem;
    flex-wrap: wrap;
  }

  .mine-verify-pill {
    display: inline-flex;
    align-items: center;
    gap: .2rem;
    min-height: 1rem;
    padding: 0 .42rem;
    border-radius: 999px;
    background: rgba(255,255,255,.14);
    color: rgba(255,255,255,.96);
    font-size: .52rem;
    font-weight: 500;
    letter-spacing: -.01em;
  }

  .mine-verify-pill.is-muted {
    color: rgba(255,255,255,.86);
  }

  .mine-verify-pill svg {
    width: .6rem;
    height: .6rem;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
  }

  .mine-pill {
    display: inline-flex;
    align-items: center;
    gap: .24rem;
    min-height: 1.18rem;
    padding: 0 .56rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, .14);
    color: #fff;
    text-decoration: none;
    font-size: .58rem;
    font-weight: 600;
  }

  .mine-setting {
    color: #fff;
    text-decoration: none;
    font-size: .76rem;
    font-weight: 600;
    flex: 0 0 auto;
    margin-top: .04rem;
  }

  .mine-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .48rem;
    margin-top: .9rem;
    position: relative;
    z-index: 1;
  }

  .mine-stat {
    padding: .52rem .3rem .48rem;
    border-radius: .72rem;
    background: rgba(255,255,255,.1);
    text-align: center;
  }

  .mine-stat .v {
    font-size: .92rem;
    line-height: 1.04rem;
    font-weight: 650;
  }

  .mine-stat .k {
    margin-top: .14rem;
    font-size: .58rem;
    line-height: .8rem;
    opacity: .94;
  }

  .mine-notice {
    margin-top: .58rem;
    padding: .68rem .8rem;
    display: flex;
    align-items: center;
    gap: .42rem;
    color: var(--mine-subtle);
    font-size: .68rem;
    line-height: .92rem;
  }

  .mine-notice strong {
    color: var(--mine-accent);
    flex: 0 0 auto;
  }

  .mine-notice-slider {
    min-width: 0;
    flex: 1 1 auto;
    overflow: hidden;
    height: .96rem;
  }

  .mine-notice .toutiao-track {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mine-notice .toutiao-item {
    height: .96rem;
    display: flex;
    align-items: center;
  }

  .mine-notice .toutiao-item a {
    display: block;
    min-width: 0;
    color: var(--mine-subtle);
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mine-section {
    margin-top: .62rem;
    padding: .88rem .82rem .74rem;
  }

  .mine-section-title {
    margin: 0 0 .74rem;
    font-size: .9rem;
    line-height: 1.1rem;
    color: var(--mine-text);
    font-weight: 700;
    letter-spacing: -.01em;
  }

  .mine-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: .9rem .18rem;
  }

  .mine-item {
    text-decoration: none;
    color: var(--mine-text);
    text-align: center;
  }

  .mine-item-icon {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: .72rem;
    margin: 0 auto .42rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.08rem;
    background: linear-gradient(180deg, #f9fafb, #eef2f7);
    box-shadow: inset 0 0 0 1px rgba(15, 23, 42, .05);
  }

  .mine-item-icon svg {
    width: 1.1rem;
    height: 1.1rem;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .mine-item-label {
    font-size: .67rem;
    line-height: .9rem;
    letter-spacing: -.01em;
  }

  .mine-item-sub {
    margin-top: .08rem;
    font-size: .54rem;
    line-height: .74rem;
    color: #9aa3b2;
  }

  .mine-links {
    margin-top: .62rem;
    overflow: hidden;
  }

  .mine-link-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .8rem;
    padding: .84rem .84rem;
    text-decoration: none;
    color: var(--mine-text);
    border-bottom: 1px solid #eff2f6;
  }

  .mine-link-row:last-child {
    border-bottom: 0;
  }

  .mine-link-row .left {
    font-size: .82rem;
    font-weight: 600;
  }

  .mine-link-row .right {
    font-size: .72rem;
    color: #9aa3b2;
    white-space: nowrap;
  }
</style>

<div class="mine-page">
  <section class="mine-card mine-hero">
    <div class="mine-topbar">
      <div class="mine-user">
        <a class="mine-avatar-link" href="/plugin.php?id=xigua_hb&ac=profile_edit&high=4" aria-label="编辑个人资料">
          <img class="mine-avatar" src="<%= data.user.avatar %>" alt="<%= data.user.nickname %>">
        </a>
        <div class="mine-copy">
          <div class="mine-name"><%= data.user.nickname %></div>
          <div class="mine-subactions">
            <a class="mine-pill" href="/plugin.php?id=xigua_hh&mobile=2&ac=my&idu=5">🤝 加盟合伙人</a>
            <span class="mine-pill">UID:<%= data.user.id %></span>
          </div>
          <div class="mine-verify-row">
            <span class="mine-verify-pill">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8.7 12.4 2.2 2.2 4.8-4.8"/><path d="M12 3.8 18.2 6v5.7c0 3.7-2.6 6.1-6.2 7.8-3.6-1.7-6.2-4.1-6.2-7.8V6L12 3.8Z"/></svg>
              <span><%= data.user.verificationBadge?.personalApproved ? '个人认证' : '未实名' %></span>
            </span>
            <span class="mine-verify-pill <%= data.user.verificationBadge?.businessApproved ? '' : 'is-muted' %>">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8.7 12.4 2.2 2.2 4.8-4.8"/><path d="M12 3.8 18.2 6v5.7c0 3.7-2.6 6.1-6.2 7.8-3.6-1.7-6.2-4.1-6.2-7.8V6L12 3.8Z"/></svg>
              <span><%= data.user.verificationBadge?.businessApproved ? '企业认证' : '未企业认证' %></span>
            </span>
          </div>
        </div>
      </div>
      <a class="mine-setting" href="/plugin.php?id=xigua_hb&ac=settings&high=4">设置</a>
    </div>

    <div class="mine-stats">
      <div class="mine-stat">
        <div class="v"><%= data.stats.totalPosts %></div>
        <div class="k">总发布</div>
      </div>
      <div class="mine-stat">
        <div class="v"><%= data.stats.totalViews %></div>
        <div class="k">总浏览量</div>
      </div>
      <div class="mine-stat">
        <div class="v"><%= data.stats.myViews %></div>
        <div class="k">我的浏览量</div>
      </div>
    </div>
  </section>

  <section class="mine-card mine-notice">
    <strong>📢平台公告</strong>
    <div class="mine-notice-slider" id="newsSlider" data-count="<%= (data.tickerItems || []).length %>">
      <ul class="toutiao-track">
        <% ((data.tickerItems && data.tickerItems.length) ? data.tickerItems : [{ text: "平台不能保证信息真实性，请勿提前支付任何费用", href: "" }]).forEach((item) => { %>
          <li class="toutiao-item">
            <a class="<%= item.href ? 'is-link' : '' %>" href="<%= item.href || 'javascript:;' %>"><%= item.text %></a>
          </li>
        <% }) %>
      </ul>
    </div>
  </section>

