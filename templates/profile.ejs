      <a class="mine-item" href="/plugin.php?id=xigua_wr&high=1"><div class="mine-item-icon" style="color:#ff6d86;"><img class="mine-icon-img" src="/source/plugin/xigua_wr/static/img/qiandao_on.png" alt=""></div><div class="mine-item-label">每日签到</div></a>
      <a class="mine-item" href="/plugin.php?id=xigua_hb&ac=coupons&high=4"><div class="mine-item-icon" style="color:#ff6d86;"><img class="mine-icon-img" src="/source/plugin/xigua_wr/static/img/duihuan_on.png" alt=""></div><div class="mine-item-label">我的兑换</div></a>
      <a class="mine-item" href="/plugin.php?id=xigua_hb&ac=subscriptions&high=4"><div class="mine-item-icon" style="color:#f5b93c;"><img class="mine-icon-img" src="/source/plugin/xigua_hb/static/dy/dy.png" alt=""></div><div class="mine-item-label">我的订阅</div></a>
      <a class="mine-item" href="/plugin.php?id=xigua_hb&ac=settings&high=4"><div class="mine-item-icon" style="color:#f47f39;"><i class="iconfont icon-weizhidingwei" aria-hidden="true"></i></div><div class="mine-item-label">收货地址</div></a>
      <a class="mine-item" href="/plugin.php?id=xigua_hb&ac=verify&high=4"><div class="mine-item-icon" style="color:#73d296;"><i class="iconfont icon-yanzheng" aria-hidden="true"></i></div><div class="mine-item-label">认证中心</div></a>
