        </div>
      </div>

      <div class="detail-desc"><%= plainContent %></div>

      <div class="detail-contact-row">
        <div>联系时请告知在 拉面联盟 上看到的</div>
        <a class="detail-call-btn" href="<%= phoneHref %>">打电话</a>
      </div>

      <div class="detail-tip">提醒：请核实出发时间和上车地点，涉及费用请电话确认。</div>

      <div class="detail-stats">
        <span>♡ <%= post.likes %></span>
        <span>◉ 浏览量 <%= post.views %></span>
        <span>↗ 分享 <%= post.shares %></span>
        <span>☆ 收藏 0</span>
      </div>
    </div>
  <% } else { %>
    <div class="detail-page">
      <div class="detail-user">
        <img class="detail-avatar" src="<%= post.avatar %>" alt="<%= post.nickname %>">
        <div class="detail-user-main">
          <div class="detail-user-name"><span><%= post.nickname %></span></div>
          <div class="detail-badges">
            <span class="detail-badge green"><%= post.category_name || "信息" %></span>
            <% safeTags.forEach((tag) => { %><span class="detail-badge outline"><%= tag %></span><% }) %>
            <span class="detail-meta-inline">来自<%= post.location %>&nbsp;&nbsp;<%= relativeText %>发布</span>
          </div>
        </div>
      </div>
      <div class="detail-desc"><%= plainContent %></div>
      <div class="detail-contact-row">
        <div>联系时请告知在 拉面联盟 上看到的</div>
        <a class="detail-call-btn" href="<%= phoneHref %>">打电话</a>
      </div>
      <div class="detail-stats">
        <span>♡ <%= post.likes %></span>
        <span>◉ 浏览量 <%= post.views %></span>
        <span>↗ 分享 <%= post.shares %></span>
        <span>☆ 收藏 0</span>
      </div>
    </div>
  <% } %>
</div>

