<div class="detail-shell">
  <div class="detail-topbar">
    <a href="javascript:history.back()">‹ 返回</a>
    <div class="title"><%= `${titlePrefix} ${post.title}` %></div>
    <a href="/plugin.php?id=xigua_hb&ac=pub&high=2" style="text-align:right;">发布</a>
  </div>

  <% if (isRecruit) { %>
    <div class="detail-page">
      <div class="detail-user">
        <img class="detail-avatar" src="<%= post.avatar %>" alt="<%= post.nickname %>">
        <div class="detail-user-main">
          <div class="detail-user-name">
            <span><%= post.nickname %></span>
            <span class="detail-auth">企业认证</span>
          </div>
          <div class="detail-badges">
            <span class="detail-badge green">招聘</span>
            <span class="detail-badge green"><%= recruitRole %></span>
            <span class="detail-badge top">置顶</span>
            <span class="detail-meta-inline">来自<%= post.location %>&nbsp;&nbsp;<%= relativeText %>发布</span>
          </div>
        </div>
      </div>

      <div class="detail-info-list">
        <div class="detail-info-row"><span class="detail-info-label">招聘职位：</span><span><%= recruitRole %></span></div>
        <div class="detail-info-row"><span class="detail-info-label">招聘人数：</span><span><%= recruitCount %></span></div>
        <div class="detail-info-row"><span class="detail-info-label">招聘条件：</span><span><%= recruitConditions %></span></div>
        <div class="detail-info-row"><span class="detail-info-label">工作内容：</span><span><%= recruitDuty %></span></div>
        <div class="detail-info-row"><span class="detail-info-label">工作地点：</span><span><%= post.location %></span></div>
        <div class="detail-info-row"><span class="detail-info-label">薪资待遇：</span><span><%= post.price_label || "面议" %></span></div>
        <div class="detail-info-row"><span class="detail-info-label">待遇：</span><span><%= recruitBenefits %></span></div>
        <div class="detail-info-row"><span class="detail-info-label">有效期：</span><span><%= recruitExpiry %></span></div>
      </div>

      <div class="detail-desc"><%= plainContent %></div>

      <div class="detail-card">
        <div class="detail-card-title">公司信息 <span class="detail-auth">已认证</span></div>
        <div class="detail-card-line">
          <div class="detail-company">
            <div class="company-logo">企</div>
            <div class="company-name">
              <div><%= `${post.city || "本地"}${post.nickname}` %></div>
              <div>信用代码：92231083MA19FU3R0G</div>
            </div>
          </div>
          <div class="detail-desc" style="margin-top:.65rem;">企业介绍：<%= post.bio || "主营兰州牛肉面，提供手工牛肉拉面和西北风味快餐，门店长期稳定经营。" %></div>
        </div>
      </div>

      <div class="detail-contact-row">
        <div>联系时请告知在 拉面联盟 上看到的</div>
        <a class="detail-call-btn" href="<%= phoneHref %>">打电话</a>
      </div>

      <div class="detail-stats">
        <span>♡ <%= post.likes %></span>
        <span>◉ 浏览量 <%= post.views %></span>
        <span>↗ 分享 <%= post.shares %></span>
        <span>☆ 收藏 0</span>
      </div>
    </div>
  <% } else if (isJobWanted) { %>
    <div class="detail-page">
      <div class="detail-user">
        <img class="detail-avatar" src="<%= post.avatar %>" alt="<%= post.nickname %>">
        <div class="detail-user-main">
          <div class="detail-user-name">
            <span><%= post.nickname %></span>
            <span class="detail-auth">个人认证</span>
          </div>
          <div class="detail-badges">
            <span class="detail-badge green">求职</span>
            <span class="detail-badge green"><%= safeTags[0] || "两口求职" %></span>
            <span class="detail-meta-inline">来自<%= post.location %>&nbsp;&nbsp;<%= relativeText %>发布</span>
          </div>
        </div>
      </div>

      <div class="detail-desc" style="font-size:.92rem;line-height:1.62rem;margin-top:.9rem;"><%= jobIntro %></div>

      <div class="detail-badges" style="margin-top:.72rem;">
        <% jobSkills.forEach((tag) => { %>
          <span class="detail-badge outline"><%= tag %></span>
        <% }) %>
      </div>

      <div class="detail-contact-row">
        <div>联系时请告知在 拉面联盟 上看到的</div>
        <a class="detail-call-btn" href="<%= phoneHref %>">打电话</a>
      </div>

      <div class="detail-tip">提醒：平台不能保证信息真实性，请提前支付任何费用！</div>

      <div class="detail-stats">
        <span>♡ <%= post.likes %></span>
        <span>◉ 浏览量 <%= post.views %></span>
        <span>↗ 分享 <%= post.shares %></span>
        <span>☆ 收藏 0</span>
      </div>

      <div class="detail-group-box">
        <a class="detail-group-btn" href="javascript:openModal('home-link-group')">拉面群</a>
        <div class="detail-group-text">←邀请你加入你所在城市的拉面群</div>
      </div>
    </div>
  <% } else if (Number(post.category_id) === 1038) { %>
    <div class="detail-page">
      <div class="detail-user">
        <img class="detail-avatar" src="<%= post.avatar %>" alt="<%= post.nickname %>">
        <div class="detail-user-main">
          <div class="detail-user-name">
            <span><%= post.nickname %></span>
          </div>
          <div class="detail-badges">
            <span class="detail-badge green"><%= rideType %></span>
            <span class="detail-badge green"><%= `${rideOrigin}→${rideDestination}` %></span>
