<div id="detailToast" class="detail-toast" aria-live="polite"></div>

<script>
  (() => {
    const toast = document.getElementById("detailToast");
    const backLink = document.getElementById("detailBackLink");
    const favoriteLinks = Array.from(document.querySelectorAll(".detail-favorite-link"));
    let toastTimer = null;

    if (backLink) {
      const ref = document.referrer;
      try {
        if (ref) {
          const refUrl = new URL(ref, window.location.origin);
          const currentUrl = new URL(window.location.href);
          if (refUrl.origin === currentUrl.origin && refUrl.href !== currentUrl.href) {
            backLink.href = refUrl.href;
          }
        }
      } catch (_error) {
        // keep fallback href
      }
    }

    if (!toast || !favoriteLinks.length) return;

    const showToast = (message) => {
      toast.textContent = message;
      toast.classList.add("is-show");
      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.classList.remove("is-show");
      }, 1600);
    };

    const updateFavoriteText = (favorited) => {
      const text = favorited ? "★ 已收藏" : "☆ 收藏";
      favoriteLinks.forEach((link) => {
        link.textContent = text;
      });
    };

    favoriteLinks.forEach((link) => {
      link.addEventListener("click", async (event) => {
        event.preventDefault();
        event.stopPropagation();
        try {
          const response = await fetch(`${link.href}${link.href.includes("?") ? "&" : "?"}ajax=1`, {
            headers: { "X-Requested-With": "XMLHttpRequest" }
          });
          const result = await response.json().catch(() => ({ ok: false, message: "操作失败，请重试" }));
          if (!response.ok || !result.ok) {
            showToast(result.message || "操作失败，请重试");
            return;
          }
          updateFavoriteText(Boolean(result.favorited));
          showToast(result.message || "已收藏");
        } catch (_error) {
          showToast("操作失败，请重试");
        }
      });
    });
  })();
</script>
