<%- include("partials/head", { pageTitle }) %>
<%
  const isRecruit = Number(post.category_id) === 1035;
  const isJobWanted = Number(post.category_id) === 1034;
  const cleanTags = (post.tags || []).filter(Boolean);
  const safeTags = cleanTags.slice(0, 3);
  const titlePrefix = isRecruit ? "[招聘信息]" : (isJobWanted ? "[求职信息]" : `[${post.category_name || "信息"}]`);
  const relativeText = String(post.created_at).slice(5, 16).replace(" ", " ");
  const plainContent = String(post.content || post.summary || "").trim();
  const contentSentences = plainContent.split(/[。！!？?]/).map((item) => item.trim()).filter(Boolean);
  const phoneHref = post.phone ? `/plugin.php?id=xigua_hb&ac=call&pubid=${post.id}` : "javascript:;";
  const favoriteHref = `/plugin.php?id=xigua_hb&ac=favorite&pubid=${post.id}`;
  const favoriteLabel = typeof isFavorited !== "undefined" && isFavorited ? "★ 已收藏" : "☆ 收藏";
  const recruitCountMatch = plainContent.match(/(\d+)\s*(名|人)/) || String(post.title || "").match(/(\d+)\s*(名|人)/);
  const recruitCount = recruitCountMatch ? `${recruitCountMatch[1]}人` : "面议";
  const recruitRolePool = cleanTags.filter((tag) => !["招聘", "置顶", "包食宿", "夫妻工", "分红"].includes(tag));
  const recruitRole = recruitRolePool.length ? recruitRolePool.join("、") : (String(post.title).includes("跑堂") ? "跑堂、前厅" : String(post.title).includes("面匠") ? "面匠" : "面匠、帮厨");
  const recruitConditions = post.summary || "要求长期稳定，踏实认真，能配合门店安排。";
  const recruitDuty = contentSentences[0] || plainContent || "负责门店日常岗位工作。";
  const recruitBenefits = cleanTags.length ? cleanTags.join("、") : (post.bio || "包吃住，设备齐全，工资按时发放");
  const recruitExpiry = "15天";
  const jobSkills = cleanTags.length ? cleanTags.slice(0, 2) : ["面匠", "炒匠"];
  const jobIntro = plainContent || post.summary || "本人长期从事拉面相关工作，可尽快到岗。";
  const rideMatch = String(post.title || "").match(/([^，,\s]+)\s*到\s*([^，,\s]+)/) || String(post.content || "").match(/([^，,\s]+)\s*到\s*([^，,\s]+)/);
  const rideOrigin = rideMatch ? String(rideMatch[1]).replace(/顺风车.*$/, "").trim() : "出发地";
  const rideDestination = rideMatch ? String(rideMatch[2]).replace(/顺风车.*$/, "").trim() : "目的地";
  const rideType = String((safeTags[0] || "")).includes("人找车") ? "人找车" : String((safeTags[0] || "")).includes("长期") ? "长期线路车" : "车找人";
  const rideDeparture = (String(post.content || "").match(/出发时间[:：]([^，。]+)/) || String(post.content || "").match(/([今明后]天[^，。]*)/) || [])[1] || "时间待定";
  const ridePassengers = (String(post.content || "").match(/人数说明[:：]([^，。]+)/) || [])[1] || post.summary || "可电话沟通";
  const rideFee = (String(post.content || "").match(/费用说明[:：]([^，。]+)/) || [])[1] || post.price_label || "电话联系";
  const detailBackHref = post.category_id
    ? `/plugin.php?id=xigua_hb&ac=cat&cat_id=${post.category_id}`
    : "/plugin.php?id=xigua_hb&mobile=2&high=0";
  const anyVerified = verificationBadge?.businessApproved || verificationBadge?.personalApproved;
  const genericAuthText = verificationBadge?.businessApproved
    ? "企业认证"
    : verificationBadge?.personalApproved
      ? "个人认证"
      : "未认证";
  const genericAuthApproved = anyVerified;
%>

