<%- include("partials/head", { pageTitle, message: "" }) %>
<%
  const isPrivilege = data.mode === "privilege";
  const nickname = data.user?.nickname || "用户";
  const latestEvent = data.latestEarningEvent;
  const latestEventTime = latestEvent?.createdAt ? latestEvent.createdAt.replace(/-/g, "-") : "";
%>
<style>
  .partner-shell {
    min-height: 100vh;
    background: #f6f7fb;
    padding-bottom: 5rem;
  }

  .partner-header {
    position: relative;
    height: 2.35rem;
    background: #35c96d;
    color: #fff;
    font-size: .84rem;
    font-weight: 600;
  }

  .partner-header a,
  .partner-header span {
    color: #fff;
    text-decoration: none;
  }

  .partner-header > a:first-child,
  .partner-header > a:last-child,
  .partner-header > span:last-child {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    min-height: 1.2rem;
    z-index: 1;
  }

  .partner-header > a:first-child {
    left: .72rem;
  }

  .partner-header > a:last-child,
  .partner-header > span:last-child {
    right: .72rem;
    justify-content: flex-end;
    min-width: 2.6rem;
  }

  .partner-header-center {
    position: absolute;
    left: 3.4rem;
    right: 3.4rem;
    top: 50%;
    transform: translateY(-50%);
    text-align: center;
    font-weight: 650;
    font-size: .84rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 0;
  }

  .partner-status-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .34rem;
    margin-top: .52rem;
    flex-wrap: wrap;
  }

  .partner-status-pill {
    display: inline-flex;
    align-items: center;
    gap: .22rem;
    min-height: 1rem;
    padding: 0 .42rem;
    border-radius: 999px;
    background: rgba(255,255,255,.14);
    color: rgba(255,255,255,.96);
    font-size: .54rem;
    font-weight: 500;
  }

  .partner-status-pill svg,
  .partner-menu-icon svg,
  .partner-metric-icon svg {
    width: .72rem;
    height: .72rem;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .partner-detail-hero {
    position: relative;
    background: #5fd37f;
    overflow: hidden;
    color: #fff;
    padding: .9rem .8rem 1rem;
  }

  .partner-detail-hero::before,
  .partner-detail-hero::after {
    content: "";
    position: absolute;
    background: rgba(255, 255, 255, .12);
    border-radius: 999px;
    transform: rotate(35deg);
  }

  .partner-detail-hero::before {
    right: .55rem;
    top: .45rem;
    width: .8rem;
    height: 2rem;
  }

  .partner-detail-hero::after {
    left: .2rem;
    top: .3rem;
    width: .5rem;
    height: .5rem;
  }

  .partner-income-main {
    text-align: center;
    padding-top: .25rem;
  }

  .partner-income-main .money {
    font-size: 1.2rem;
    line-height: 1.35rem;
    font-weight: 300;
    letter-spacing: .01em;
  }

  .partner-income-main .label {
    margin-top: .12rem;
    font-size: .66rem;
    opacity: .95;
  }

  .partner-income-sub {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .4rem;
    text-align: center;
  }

  .partner-income-sub .value {
    font-size: .82rem;
    line-height: 1rem;
    font-weight: 500;
  }

  .partner-income-sub .caption {
    margin-top: .08rem;
    font-size: .62rem;
    opacity: .95;
  }

  .partner-latest {
    display: flex;
    align-items: center;
    gap: .35rem;
    height: 1.7rem;
    background: #fff;
    padding: 0 .65rem;
    border-bottom: 1px solid #eff2f6;
    font-size: .68rem;
    color: #5f6977;
  }

  .partner-latest strong {
    color: #58c56f;
    font-weight: 700;
  }

  .partner-latest .amount {
    color: #ff6666;
    font-weight: 700;
  }

  .partner-menu {
    margin-top: .35rem;
    background: #fff;
  }

  .partner-menu-item {
    height: 2.45rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 .72rem;
    border-bottom: 1px solid #f1f3f6;
    color: #2d3746;
    text-decoration: none;
    font-size: .82rem;
  }

  .partner-menu-item:last-child {
    border-bottom: 0;
  }

  .partner-menu-left {
    display: inline-flex;
    align-items: center;
    gap: .34rem;
  }

  .partner-menu-icon {
    width: .92rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .partner-menu-right {
    display: inline-flex;
    align-items: center;
    gap: .2rem;
    color: #8a95a5;
    font-size: .74rem;
  }

  .partner-menu-right .accent {
    color: #58c56f;
    font-weight: 600;
  }

  .partner-menu-right .warn {
    color: #ff6767;
    font-weight: 600;
  }

  .partner-menu-right .arrow {
    color: #c3cad4;
    font-size: .9rem;
  }

  .partner-metric-icon {
    width: 1rem;
    height: 1rem;
    margin: 0 auto .18rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #58c56f;
  }

  .partner-banner {
    margin: 0;
    height: 9rem;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(0deg, rgba(235, 214, 91, .95), rgba(235, 214, 91, .95)),
      radial-gradient(circle at 20% 28%, rgba(255,255,255,.18), transparent 16%);
  }

  .partner-banner::before {
    content: "";
    position: absolute;
    left: -8%;
    right: -8%;
    top: 1rem;
    height: 1rem;
    background: #d93e45;
    border-top: .12rem solid #473533;
    border-bottom: .12rem solid #473533;
    transform: rotate(-5deg);
  }

  .partner-banner::after {
    content: "";
    position: absolute;
    left: -10%;
    right: -10%;
    bottom: 1.55rem;
    height: .95rem;
    background: #d93e45;
    border-top: .12rem solid #473533;
    border-bottom: .12rem solid #473533;
    transform: rotate(-4deg);
  }

  .partner-poster {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: .2rem;
    z-index: 1;
  }

  .partner-poster-main {
    padding: .2rem .75rem;
    background: #d98946;
    border: .12rem solid #5f412d;
    color: #fff;
    font-size: 1.22rem;
    line-height: 1.4rem;
    font-weight: 900;
    letter-spacing: .03em;
    text-align: center;
    box-shadow: 0 .12rem 0 rgba(79, 52, 39, .45);
    transform: rotate(-4deg);
    text-shadow: 0 .08rem 0 rgba(77, 56, 45, .55);
  }

  .partner-poster-sub {
    margin-top: .25rem;
    padding: .08rem .72rem;
    background: #58d0e6;
    border: .12rem solid #3a3d3d;
    color: #1e2732;
    font-size: .74rem;
    line-height: 1rem;
    font-weight: 900;
    transform: rotate(-2deg);
  }

  .partner-poster-dot {
    width: .8rem;
    height: .18rem;
    border-radius: 999px;
    background: #7bd487;
    margin-top: .28rem;
  }

  .partner-body {
    padding: .58rem .58rem 0;
  }

  .partner-label {
    color: #8f99aa;
    font-size: .66rem;
    line-height: .95rem;
    margin-bottom: .36rem;
  }

  .partner-level-card,
  .partner-note-box,
  .partner-cta {
    background: #fff;
    border-radius: .78rem;
    box-shadow: 0 .1rem .32rem rgba(15, 23, 42, .05);
  }

  .partner-level-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .86rem .9rem;
    color: #273142;
    font-size: .88rem;
    font-weight: 700;
  }

  .partner-level-card .arrow {
    color: #c2c8d2;
    font-size: .96rem;
  }

  .partner-grid-label {
    margin-top: .68rem;
    margin-bottom: .34rem;
    color: #8f99aa;
    font-size: .66rem;
  }

  .partner-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: #fff;
    border-radius: .88rem;
    overflow: hidden;
    box-shadow: 0 .1rem .32rem rgba(15, 23, 42, .05);
  }

  .partner-metric {
    min-height: 5.7rem;
    display: grid;
    place-items: center;
    text-align: center;
    padding: .6rem .22rem;
    border-right: 1px solid #edf1f6;
  }

  .partner-metric:last-child {
    border-right: 0;
  }

  .partner-metric-icon {
    font-size: 1rem;
    line-height: 1;
    margin-bottom: .2rem;
  }

  .partner-metric-title {
    color: #8d97a9;
    font-size: .68rem;
    line-height: .95rem;
  }

  .partner-metric-value {
    color: #35c96d;
    font-size: .74rem;
    line-height: 1rem;
    font-weight: 700;
    margin-top: .12rem;
  }

  .partner-copy {
    margin-top: .64rem;
    color: #434d5c;
    font-size: .76rem;
    line-height: 1.28rem;
  }

  .partner-copy strong {
    color: #35c96d;
    font-weight: 800;
  }

  .partner-note-box {
    margin-top: .5rem;
    border: 1px solid rgba(53, 201, 109, .68);
    padding: .72rem .78rem;
    color: #576170;
    font-size: .7rem;
    line-height: 1.14rem;
  }

  .partner-cta {
    margin-top: .88rem;
    width: 100%;
    border: 0;
    background: #35c96d;
    color: #fff;
    height: 2.45rem;
    font-size: .94rem;
    font-weight: 800;
    border-radius: .78rem;
  }

  .partner-sheet {
    position: fixed;
    inset: 0;
    z-index: 160;
    display: none;
  }

  .partner-sheet.is-open {
    display: block;
  }

  .partner-sheet-mask {
    position: absolute;
    inset: 0;
    background: rgba(10, 14, 24, .42);
  }

  .partner-sheet-panel {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 0 .62rem calc(.72rem + env(safe-area-inset-bottom));
  }

  .partner-sheet-title {
    height: 2.55rem;
    display: grid;
    place-items: center;
    background: #fff;
    border-radius: .96rem .96rem 0 0;
    color: #ff766f;
    font-size: .84rem;
    font-weight: 800;
    box-shadow: 0 -.12rem .42rem rgba(15, 23, 42, .08);
  }

  .partner-sheet-actions {
    background: #f7f8fb;
    padding: .5rem 0 0;
    border-radius: 0 0 .96rem .96rem;
  }

  .partner-sheet-form {
    margin: 0;
  }

  .partner-sheet-option,
  .partner-sheet-cancel {
    width: 100%;
    height: 2.45rem;
    border: 0;
    background: #fff;
    color: #263141;
    font-size: .9rem;
    font-weight: 700;
    margin-bottom: .45rem;
    border-radius: .66rem;
  }

  .partner-sheet-cancel {
    margin-top: .1rem;
  }
</style>

<div class="partner-shell">
  <% if (!isPrivilege) { %>
    <div class="partner-header">
      <a class="ui-back-link is-light" href="/plugin.php?id=xigua_hb&ac=my&high=4"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7"/></svg><span>返回</span></a>
      <div class="partner-header-center">金牌合伙人-<%= nickname %></div>
      <a href="/plugin.php?id=xigua_hh&mobile=2&ac=my&idu=5&view=privilege">等级特权</a>
    </div>

    <div class="partner-detail-hero">
      <div class="partner-income-main">
        <div class="money">¥<%= Number(data.todayIncome || 0).toFixed(2) %></div>
        <div class="label">今日收入</div>
      </div>
      <div class="partner-status-row">
        <span class="partner-status-pill">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8.7 12.4 2.2 2.2 4.8-4.8"/><path d="M12 3.8 18.2 6v5.7c0 3.7-2.6 6.1-6.2 7.8-3.6-1.7-6.2-4.1-6.2-7.8V6L12 3.8Z"/></svg>
          <span><%= data.user?.verificationBadge?.businessApproved ? '企业认证' : data.user?.verificationBadge?.personalApproved ? '个人认证' : '未认证' %></span>
        </span>
        <span class="partner-status-pill">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 12.2h9"/><path d="M12 7.7v9"/><path d="M19 12a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/></svg>
          <span><%= data.verification?.depositStatusText || '未缴纳' %></span>
        </span>
      </div>
      <div class="partner-income-sub">
        <div>
          <div class="value">¥<%= Number(data.withdrawable || 0).toFixed(2) %></div>
          <div class="caption">可提现</div>
        </div>
        <div>
          <div class="value">¥<%= Number(data.totalCommission || 0).toFixed(2) %></div>
          <div class="caption">累计提成</div>
        </div>
      </div>
    </div>

    <div class="partner-latest">
      <strong>最新收益</strong>
      <% if (latestEvent) { %>
        <span><%= latestEvent.nickname %> <%= latestEventTime %> 提现</span>
        <span class="amount"><%= Number(latestEvent.amount || 0) %>元</span>
      <% } else { %>
        <span>暂无最新收益</span>
      <% } %>
    </div>

    <div class="partner-menu">
      <a class="partner-menu-item" href="/plugin.php?id=xigua_hh&mobile=2&ac=my&idu=5&view=privilege">
        <span class="partner-menu-left"><span class="partner-menu-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8.2 10.3 2.8 2.7 2-2 2.8 2.8"/><path d="M6.5 8.8 4.5 6.9a2.2 2.2 0 0 1 3.1-3.1l1.6 1.6"/><path d="m17.5 8.8 2-1.9a2.2 2.2 0 0 0-3.1-3.1l-1.6 1.6"/><path d="M7.5 12.5 5.7 14.3a2.2 2.2 0 1 0 3.1 3.1l1.8-1.8"/><path d="m16.5 12.5 1.8 1.8a2.2 2.2 0 1 1-3.1 3.1l-1.8-1.8"/></svg></span><span>金牌合伙人</span></span>
        <span class="partner-menu-right"><span class="<%= data.latestOrderStatusLabel === '待支付' ? 'warn' : 'accent' %>"><%= data.latestOrderStatusLabel %></span><span class="arrow">›</span></span>
      </a>
      <a class="partner-menu-item" href="/plugin.php?id=xigua_hh&mobile=2&ac=my&idu=5&view=fans">
        <span class="partner-menu-left"><span class="partner-menu-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="9" cy="9" r="2.6"/><circle cx="16.5" cy="10.2" r="2.1"/><path d="M4.8 18.2c1.1-2.2 3-3.4 5.2-3.4s4 1.2 5.1 3.4"/><path d="M14.2 17.7c.6-1.4 1.8-2.2 3.4-2.2 1 0 1.9.3 2.6.9"/></svg></span><span>我的粉丝</span></span>
        <span class="partner-menu-right"><span class="accent"><%= Number(data.fanCount || 0) %></span><span class="arrow">›</span></span>
      </a>
      <a class="partner-menu-item" href="/plugin.php?id=xigua_hh&mobile=2&ac=my&idu=5&view=income">
        <span class="partner-menu-left"><span class="partner-menu-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><ellipse cx="12" cy="8" rx="5.5" ry="2.8"/><path d="M6.5 8v6c0 1.5 2.5 2.8 5.5 2.8s5.5-1.3 5.5-2.8V8"/><path d="M12 10.2v3.8"/><path d="M10.2 12.1H13.8"/></svg></span><span>收入明细</span></span>
        <span class="partner-menu-right"><span class="arrow">›</span></span>
      </a>
      <a class="partner-menu-item" href="/plugin.php?id=xigua_hh&mobile=2&ac=my&idu=5&view=trend">
        <span class="partner-menu-left"><span class="partner-menu-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.5 18.5h13"/><path d="M7.5 15.5 11 12l2.6 2.3 3.9-5"/></svg></span><span>收入趋势</span></span>
        <span class="partner-menu-right"><span class="arrow">›</span></span>
      </a>
      <a class="partner-menu-item" href="/plugin.php?id=xigua_hb&ac=qianbao">
        <span class="partner-menu-left"><span class="partner-menu-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 8.5h15v10h-15z"/><path d="M4.5 8.5V7a2 2 0 0 1 2-2h8"/><path d="M15.5 13h4"/></svg></span><span>我的钱包</span></span>
        <span class="partner-menu-right"><span>¥<%= Number(data.wallet?.balance || 0).toFixed(2) %></span><span class="arrow">›</span></span>
      </a>
      <a class="partner-menu-item" href="/plugin.php?id=xigua_hh&mobile=2&ac=my&idu=5&view=rules">
        <span class="partner-menu-left"><span class="partner-menu-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="7"/><path d="M9.9 9.5a2.3 2.3 0 1 1 3 2.2c-.8.3-1.2.8-1.2 1.6"/><path d="M11.8 16.6h.1"/></svg></span><span>规则说明</span></span>
        <span class="partner-menu-right"><span class="arrow">›</span></span>
      </a>
      <a class="partner-menu-item" href="/plugin.php?id=xigua_lt&type=thread&channel=martin&mobile=2&high=3">
        <span class="partner-menu-left"><span class="partner-menu-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 5.8c.5-.5 1.3-.5 1.8 0l1.7 1.7c.5.5.5 1.3 0 1.8l-1.1 1.1a13 13 0 0 0 4.8 4.8l1.1-1.1c.5-.5 1.3-.5 1.8 0l1.7 1.7c.5.5.5 1.3 0 1.8l-1.1 1.1c-.7.7-1.7 1-2.7.8A17 17 0 0 1 4.2 8.8c-.2-1 .1-2 .8-2.7z"/></svg></span><span>联系客服</span></span>
        <span class="partner-menu-right"><span>有问题请找我</span><span class="arrow">›</span></span>
      </a>
    </div>
  <% } else { %>
    <div class="partner-header">
      <a class="ui-back-link is-light" href="/plugin.php?id=xigua_hh&mobile=2&ac=my&idu=5"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7"/></svg><span>返回</span></a>
      <div class="partner-header-center">等级特权</div>
      <span></span>
    </div>

    <div class="partner-banner">
      <div class="partner-poster">
        <div class="partner-poster-main">一次加入<br>永久收益</div>
        <div class="partner-poster-sub">加入合伙人躺着就能赚钱</div>
        <div class="partner-poster-dot"></div>
      </div>
    </div>

    <div class="partner-body">
      <div class="partner-label">请选择合伙人等级</div>
      <button id="partnerLevelTrigger" class="partner-level-card" type="button">
        <span><%= data.selectedLevel %></span>
        <span class="arrow">›</span>
      </button>

      <div class="partner-grid-label">费用及等级特权</div>
      <div class="partner-metrics">
        <% data.cards.forEach((item) => { %>
          <div class="partner-metric">
            <div class="partner-metric-icon">
              <% if (item.title === '加入费用') { %>
                <svg viewBox="0 0 24 24" aria-hidden="true"><ellipse cx="12" cy="8" rx="5.5" ry="2.8"/><path d="M6.5 8v6c0 1.5 2.5 2.8 5.5 2.8s5.5-1.3 5.5-2.8V8"/></svg>
              <% } else if (item.title === '提成比例') { %>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 16.5 16.5 7.5"/><circle cx="8" cy="8" r="2"/><circle cx="16" cy="16" r="2"/></svg>
              <% } else { %>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 6v6l3.5 2"/><circle cx="12" cy="12" r="7"/></svg>
              <% } %>
            </div>
            <div class="partner-metric-title"><%= item.title %></div>
            <div class="partner-metric-value"><%= item.value %></div>
          </div>
        <% }) %>
      </div>

      <div class="partner-copy">
        <strong><%= data.introTitle %></strong><br>
        <%= data.introText %><br>
        <strong><%= data.settleText %></strong>
      </div>

      <% data.notes.forEach((note) => { %>
        <div class="partner-note-box"><%= note %></div>
      <% }) %>

      <button id="partnerJoinTrigger" class="partner-cta" type="button">立即成为合伙人</button>
    </div>

    <div id="partnerSheet" class="partner-sheet" aria-hidden="true">
      <div class="partner-sheet-mask" data-partner-close></div>
      <div class="partner-sheet-panel">
        <div class="partner-sheet-title"><%= data.selectedLevel %></div>
        <div class="partner-sheet-actions">
          <% data.plans.forEach((plan) => { %>
            <form class="partner-sheet-form" method="post" action="/plugin.php?id=xigua_hh&ac=join">
              <input type="hidden" name="plan_key" value="<%= plan.key %>">
              <button class="partner-sheet-option" type="submit"><%= plan.priceLabel %></button>
            </form>
          <% }) %>
          <button class="partner-sheet-cancel" type="button" data-partner-close>取消</button>
        </div>
      </div>
    </div>

    <script>
      (() => {
        const sheet = document.getElementById("partnerSheet");
        const openButtons = [document.getElementById("partnerJoinTrigger"), document.getElementById("partnerLevelTrigger")].filter(Boolean);
        const closeButtons = Array.from(document.querySelectorAll("[data-partner-close]"));
        if (!sheet || !openButtons.length) return;

        const openSheet = () => {
          sheet.classList.add("is-open");
          sheet.setAttribute("aria-hidden", "false");
        };

        const closeSheet = () => {
          sheet.classList.remove("is-open");
          sheet.setAttribute("aria-hidden", "true");
        };

        openButtons.forEach((button) => button.addEventListener("click", openSheet));
        closeButtons.forEach((button) => button.addEventListener("click", closeSheet));
      })();
    </script>
  <% } %>
</div>

<%- include("partials/tabbar", { currentTab }) %>
