<%- include("partials/head", { pageTitle, message }) %>
<style>
  .profile-edit-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at 18% 18%, rgba(140, 95, 255, .09), transparent 26%),
      linear-gradient(180deg, #f4f5f8 0%, #eef1f6 100%);
    padding-bottom: 1rem;
  }

  .profile-edit-hero {
    position: relative;
    min-height: 13rem;
    padding: .65rem .7rem 1.35rem;
    background:
      linear-gradient(180deg, rgba(13, 12, 27, .12), rgba(17, 12, 32, .24)),
      linear-gradient(135deg, #24263a 0%, #3d2f67 34%, #5f46a8 68%, #7c57d4 100%);
    overflow: hidden;
  }

  .profile-edit-hero::before,
  .profile-edit-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .profile-edit-hero::before {
    background:
      linear-gradient(120deg, transparent 0 13%, rgba(255,255,255,.06) 13% 15%, transparent 15% 28%, rgba(255,255,255,.05) 28% 30%, transparent 30% 46%, rgba(255,255,255,.04) 46% 48%, transparent 48% 100%);
    opacity: .82;
  }

  .profile-edit-hero::after {
    background:
      radial-gradient(circle at 16% 74%, rgba(255, 101, 141, .16), transparent 18%),
      radial-gradient(circle at 82% 18%, rgba(159, 117, 255, .16), transparent 20%);
  }

  .profile-edit-topbar,
  .profile-edit-identity {
    position: relative;
    z-index: 1;
  }

  .profile-edit-topbar {
    position: relative;
    height: 2.35rem;
    color: #fff;
  }

  .profile-edit-back {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
  }

  .profile-edit-top-placeholder {
    position: absolute;
    left: 3.4rem;
    right: 3.4rem;
    top: 50%;
    transform: translateY(-50%);
    text-align: center;
    opacity: 0;
    font-size: .84rem;
    line-height: 1.1rem;
  }

  .profile-edit-identity {
    padding-top: 2.15rem;
    text-align: center;
    color: #fff;
  }

  .profile-edit-avatar-wrap {
    width: 5.2rem;
    height: 5.2rem;
    margin: 0 auto;
    position: relative;
  }

  .profile-edit-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,.94);
    background: rgba(255,255,255,.1);
    box-shadow: 0 .28rem .9rem rgba(12, 13, 27, .22);
  }

  .profile-edit-camera {
    position: absolute;
    right: -.08rem;
    bottom: .16rem;
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 50%;
    background: linear-gradient(180deg, #9fc1ff, #82abf8);
    border: 2px solid rgba(255,255,255,.96);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: .82rem;
    box-shadow: 0 .15rem .42rem rgba(11, 17, 32, .22);
  }

  .profile-edit-name {
    margin-top: .55rem;
    font-size: 1.12rem;
    line-height: 1.3rem;
    font-weight: 700;
    letter-spacing: .01em;
    text-shadow: 0 .08rem .22rem rgba(8, 10, 22, .18);
  }

  .profile-edit-card {
    margin: 0 .55rem;
    margin-top: -.05rem;
    background: rgba(255,255,255,.97);
    border-radius: .18rem;
    box-shadow:
      0 .18rem .72rem rgba(20, 24, 39, .08),
      0 .02rem .18rem rgba(20, 24, 39, .05);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.72);
  }

  .profile-edit-form {
    display: block;
  }

  .profile-edit-row {
    display: grid;
    grid-template-columns: 4.1rem 1fr;
    gap: .72rem;
    align-items: center;
    min-height: 3.05rem;
    padding: 0 .72rem;
    border-bottom: 1px solid #edf1f6;
    background: rgba(255,255,255,.96);
  }

  .profile-edit-row:last-of-type {
    border-bottom: 0;
  }

  .profile-edit-label {
    font-size: .82rem;
    color: #313846;
    line-height: 1.1rem;
    font-weight: 600;
  }

  .profile-edit-input,
  .profile-edit-select {
    width: 100%;
    min-width: 0;
    height: 2.05rem;
    border: 0;
    border-radius: .14rem;
    background: linear-gradient(180deg, #f5f6f9, #eef1f5);
    color: #2d3748;
    font-size: .8rem;
    padding: 0 .7rem;
    outline: none;
    box-sizing: border-box;
    box-shadow: inset 0 0 0 1px rgba(31, 41, 55, .04);
  }

  .profile-edit-inline {
    display: flex;
    align-items: center;
    gap: .34rem;
  }

  .profile-edit-inline .profile-edit-input {
    flex: 1 1 auto;
  }

  .profile-edit-editicon {
    color: #adb4c0;
    font-size: .88rem;
    line-height: 1;
    flex: 0 0 auto;
  }

  .profile-edit-gender {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .36rem;
  }

  .profile-edit-gender-item {
    position: relative;
  }

  .profile-edit-gender input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .profile-edit-gender label {
    height: 2.05rem;
    border-radius: .14rem;
    background: linear-gradient(180deg, #f5f6f9, #eef1f5);
    color: #596273;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .8rem;
    font-weight: 600;
    box-shadow: inset 0 0 0 1px rgba(31, 41, 55, .04);
  }

  .profile-edit-gender input:checked + label {
    background: linear-gradient(180deg, #aaafb7, #9aa1ab);
    color: #fff;
    box-shadow: inset 0 -0.04rem 0 rgba(0,0,0,.08);
  }

  .profile-edit-birthday {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .36rem;
  }

  .profile-edit-birthday-trigger {
    width: 100%;
    height: 2.05rem;
    border: 0;
    border-radius: .14rem;
    background: linear-gradient(180deg, #f5f6f9, #eef1f5);
    color: #2d3748;
    font-size: .8rem;
    padding: 0 .6rem;
    box-shadow: inset 0 0 0 1px rgba(31, 41, 55, .04);
    appearance: none;
    -webkit-appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, #96a0b0 50%),
      linear-gradient(135deg, #96a0b0 50%, transparent 50%);
    background-position:
      calc(100% - .75rem) calc(50% - .05rem),
      calc(100% - .55rem) calc(50% - .05rem);
    background-size: .24rem .24rem, .24rem .24rem;
    background-repeat: no-repeat;
    outline: none;
  }

  .profile-edit-birthday-trigger.is-empty {
    color: #98a2b3;
  }

  .profile-edit-submit-wrap {
    padding: .82rem .58rem 1rem;
    background: rgba(255,255,255,.96);
  }

  .profile-edit-submit {
    width: 100%;
    height: 2.35rem;
    border: 0;
    border-radius: .14rem;
    background: linear-gradient(180deg, #5a92f6, #3f78ee);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: .02em;
    box-shadow:
      inset 0 0.02rem 0 rgba(255,255,255,.22),
      0 .16rem .45rem rgba(63, 120, 238, .22);
  }

  .profile-edit-toast {
    position: fixed;
    top: max(.8rem, env(safe-area-inset-top));
    left: 50%;
    transform: translate(-50%, -1rem);
    min-width: 10rem;
    max-width: calc(100vw - 1.6rem);
    padding: .72rem .95rem;
    border-radius: .42rem;
    background: rgba(27, 34, 52, .92);
    color: #fff;
    font-size: .76rem;
    line-height: 1.15rem;
    text-align: center;
    box-shadow: 0 .22rem .75rem rgba(17, 24, 39, .22);
    z-index: 220;
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease, transform .2s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .profile-edit-toast.is-show {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .profile-edit-toast.is-error {
    background: rgba(194, 56, 60, .94);
  }

  .profile-edit-hidden-input {
    display: none;
  }

  .profile-edit-picker {
    position: fixed;
    inset: 0;
    z-index: 140;
    display: none;
  }

  .profile-edit-picker.is-open {
    display: block;
  }

  .profile-edit-picker-mask {
    position: absolute;
    inset: 0;
    background: rgba(8, 12, 24, .28);
  }

  .profile-edit-picker-sheet {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255,255,255,.98);
    border-radius: .9rem .9rem 0 0;
    box-shadow: 0 -.12rem .65rem rgba(15, 23, 42, .14);
    padding-bottom: .9rem;
  }

  .profile-edit-picker-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .8rem .85rem .65rem;
    border-bottom: 1px solid #edf1f6;
  }

  .profile-edit-picker-btn {
    border: 0;
    background: transparent;
    color: #7d8797;
    font-size: .8rem;
  }

  .profile-edit-picker-btn.confirm {
    color: #3f78ee;
    font-weight: 700;
  }

  .profile-edit-picker-title {
    color: #273142;
    font-size: .82rem;
    font-weight: 700;
  }

  .profile-edit-picker-body {
    padding: .8rem .78rem 0;
    background: linear-gradient(180deg, #fafbfe, #f4f7fb);
  }

  .profile-edit-picker-list {
    height: 12rem;
    overflow-y: auto;
    border-radius: .18rem;
    background: rgba(255,255,255,.88);
    box-shadow: inset 0 0 0 1px rgba(31, 41, 55, .04);
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }

  .profile-edit-picker-list::-webkit-scrollbar {
    display: none;
  }

  .profile-edit-picker-option {
    width: 100%;
    min-height: 2.35rem;
    border: 0;
    background: transparent;
    color: #667084;
    font-size: .8rem;
    line-height: 1.15rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: .55rem .4rem;
    border-bottom: 1px solid rgba(31, 41, 55, .04);
  }

  .profile-edit-picker-option.is-active {
    color: #1f2937;
    font-weight: 700;
    background: linear-gradient(180deg, #eef4ff, #e6efff);
  }

  .profile-edit-picker-subtitle {
    padding: 0 .1rem .55rem;
    color: #8b96a8;
    font-size: .7rem;
    text-align: center;
  }
</style>

<div class="profile-edit-page">
  <div id="profileEditToast" class="profile-edit-toast" aria-live="polite"></div>
  <div class="profile-edit-hero">
    <div class="profile-edit-topbar">
      <a class="profile-edit-back ui-back-link is-light" href="/plugin.php?id=xigua_hb&ac=my&high=4"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7"/></svg><span>返回</span></a>
      <span class="profile-edit-top-placeholder">占位</span>
      <span class="profile-edit-top-placeholder">占位</span>
    </div>

    <div class="profile-edit-identity">
      <div class="profile-edit-avatar-wrap">
        <img id="avatarPreview" class="profile-edit-avatar" src="<%= data.user.avatar %>" alt="<%= data.user.nickname %>">
        <label class="profile-edit-camera" for="avatarInput">📷</label>
      </div>
      <div class="profile-edit-name"><%= data.user.nickname %></div>
    </div>
  </div>

  <div class="profile-edit-card">
    <form id="profileEditForm" class="profile-edit-form" method="post" action="/profile-edit-save" enctype="multipart/form-data">
      <input type="hidden" name="avatar_current" value="<%= data.user.avatar %>">
      <input id="avatarInput" class="profile-edit-hidden-input" type="file" name="avatar" accept="image/*">

      <div class="profile-edit-row">
        <div class="profile-edit-label">用户名</div>
        <div class="profile-edit-inline">
          <input class="profile-edit-input" type="text" name="nickname" value="<%= data.user.nickname %>" placeholder="请输入用户名">
          <span class="profile-edit-editicon">✎</span>
        </div>
      </div>

      <div class="profile-edit-row">
        <div class="profile-edit-label">新密码</div>
        <input class="profile-edit-input" type="password" name="password" value="" placeholder="不修改密码请留空">
      </div>

      <div class="profile-edit-row">
        <div class="profile-edit-label">性别</div>
        <div class="profile-edit-gender">
          <div class="profile-edit-gender-item">
            <input id="genderMale" type="radio" name="gender" value="male" <%= data.user.gender === "male" ? "checked" : "" %>>
            <label for="genderMale">♂ 男生</label>
          </div>
          <div class="profile-edit-gender-item">
            <input id="genderFemale" type="radio" name="gender" value="female" <%= data.user.gender === "female" ? "checked" : "" %>>
            <label for="genderFemale">♀ 女生</label>
          </div>
          <div class="profile-edit-gender-item">
            <input id="genderSecret" type="radio" name="gender" value="secret" <%= (!data.user.gender || data.user.gender === "secret") ? "checked" : "" %>>
            <label for="genderSecret">保密</label>
          </div>
        </div>
      </div>

      <div class="profile-edit-row">
        <div class="profile-edit-label">生日</div>
        <div class="profile-edit-birthday">
          <button class="profile-edit-birthday-trigger <%= data.birthdayYear ? '' : 'is-empty' %>" type="button" data-birthday-trigger="year"><%= data.birthdayYear || '年' %></button>
          <button class="profile-edit-birthday-trigger <%= data.birthdayMonth ? '' : 'is-empty' %>" type="button" data-birthday-trigger="month"><%= data.birthdayMonth || '月' %></button>
          <button class="profile-edit-birthday-trigger <%= data.birthdayDay ? '' : 'is-empty' %>" type="button" data-birthday-trigger="day"><%= data.birthdayDay || '日' %></button>
          <input id="birthdayYear" class="profile-edit-hidden-input" type="hidden" name="birthday_year" value="<%= data.birthdayYear %>">
          <input id="birthdayMonth" class="profile-edit-hidden-input" type="hidden" name="birthday_month" value="<%= data.birthdayMonth %>">
          <input id="birthdayDay" class="profile-edit-hidden-input" type="hidden" name="birthday_day" value="<%= data.birthdayDay %>">
        </div>
      </div>

      <div class="profile-edit-submit-wrap">
        <button id="profileEditSubmit" class="profile-edit-submit" type="submit">保存</button>
      </div>
    </form>
  </div>
</div>

<div id="birthdayPicker" class="profile-edit-picker" aria-hidden="true">
  <div class="profile-edit-picker-mask" data-birthday-close></div>
  <div class="profile-edit-picker-sheet">
    <div class="profile-edit-picker-toolbar">
      <button class="profile-edit-picker-btn" type="button" data-birthday-close>取消</button>
      <div id="birthdayPickerTitle" class="profile-edit-picker-title">选择年份</div>
      <button id="birthdayPickerConfirm" class="profile-edit-picker-btn confirm" type="button">确认</button>
    </div>
    <div class="profile-edit-picker-body">
      <div id="birthdayPickerSubtitle" class="profile-edit-picker-subtitle">先选年份，再选月份和日期</div>
      <div id="birthdayPickerList" class="profile-edit-picker-list"></div>
    </div>
  </div>
</div>

<script>
  (() => {
    const input = document.getElementById("avatarInput");
    const preview = document.getElementById("avatarPreview");
    if (!input || !preview) return;
    input.addEventListener("change", () => {
      const [file] = input.files || [];
      if (!file) return;
      const objectUrl = URL.createObjectURL(file);
      preview.src = objectUrl;
    });
  })();

  (() => {
    const picker = document.getElementById("birthdayPicker");
    const pickerTitle = document.getElementById("birthdayPickerTitle");
    const pickerSubtitle = document.getElementById("birthdayPickerSubtitle");
    const pickerList = document.getElementById("birthdayPickerList");
    const confirmButton = document.getElementById("birthdayPickerConfirm");
    const yearInput = document.getElementById("birthdayYear");
    const monthInput = document.getElementById("birthdayMonth");
    const dayInput = document.getElementById("birthdayDay");
    const triggers = Array.from(document.querySelectorAll("[data-birthday-trigger]"));
    const closeButtons = Array.from(document.querySelectorAll("[data-birthday-close]"));
    if (!picker || !pickerTitle || !pickerSubtitle || !pickerList || !confirmButton || !yearInput || !monthInput || !dayInput) return;

    const inputMap = { year: yearInput, month: monthInput, day: dayInput };
    const partLabelMap = { year: "年份", month: "月份", day: "日期" };
    let activePart = "year";
    let draftValue = "";

    const syncTriggerText = () => {
      triggers.forEach((trigger) => {
        const part = trigger.dataset.birthdayTrigger;
        const value = inputMap[part].value;
        trigger.textContent = value || (part === "year" ? "年" : part === "month" ? "月" : "日");
        trigger.classList.toggle("is-empty", !value);
      });
    };

    const getValues = (part) => {
      if (part === "year") {
        return Array.from({ length: 100 }, (_, index) => String(1980 + index));
      }
      if (part === "month") {
        return Array.from({ length: 12 }, (_, index) => String(index + 1).padStart(2, "0"));
      }
      const year = Number(yearInput.value || new Date().getFullYear());
      const month = Number(monthInput.value || 1);
      const count = new Date(year, month, 0).getDate();
      return Array.from({ length: count }, (_, index) => String(index + 1).padStart(2, "0"));
    };

    const renderList = (part) => {
      const values = getValues(part);
      if (!values.includes(draftValue)) {
        draftValue = inputMap[part].value && values.includes(inputMap[part].value)
          ? inputMap[part].value
          : values[0];
      }
      pickerTitle.textContent = `选择${partLabelMap[part]}`;
      pickerSubtitle.textContent = part === "year"
        ? "向下滚动选择年份"
        : part === "month"
          ? "选择月份"
          : "选择日期";
      pickerList.innerHTML = values
        .map((value) => `<button class="profile-edit-picker-option${value === draftValue ? " is-active" : ""}" type="button" data-picker-value="${value}">${value}</button>`)
        .join("");
      requestAnimationFrame(() => {
        const target = pickerList.querySelector(`[data-picker-value="${draftValue}"]`);
        if (target) {
          target.scrollIntoView({ block: "center" });
        }
      });
      pickerList.querySelectorAll("[data-picker-value]").forEach((button) => {
        button.addEventListener("click", () => {
          draftValue = button.dataset.pickerValue;
          pickerList.querySelectorAll("[data-picker-value]").forEach((item) => item.classList.toggle("is-active", item === button));
        });
      });
    };

	    const openPicker = (part) => {
        activePart = part;
        draftValue = inputMap[part].value || "";
	      picker.classList.add("is-open");
	      picker.setAttribute("aria-hidden", "false");
	      renderList(part);
	    };

	    const closePicker = () => {
      picker.classList.remove("is-open");
      picker.setAttribute("aria-hidden", "true");
    };

	    triggers.forEach((trigger) => {
	      trigger.addEventListener("click", () => openPicker(trigger.dataset.birthdayTrigger));
	    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", closePicker);
    });

	    confirmButton.addEventListener("click", () => {
        inputMap[activePart].value = draftValue;
        if (activePart === "year") {
          const days = getValues("day");
          if (!days.includes(dayInput.value)) {
            dayInput.value = days[days.length - 1];
          }
        }
        if (activePart === "month") {
          const days = getValues("day");
          if (!days.includes(dayInput.value)) {
            dayInput.value = days[days.length - 1];
          }
        }
	      syncTriggerText();
	      closePicker();
	    });

    syncTriggerText();
  })();

  (() => {
    const form = document.getElementById("profileEditForm");
    const submitButton = document.getElementById("profileEditSubmit");
    const toast = document.getElementById("profileEditToast");
    const nameDisplay = document.querySelector(".profile-edit-name");
    let toastTimer = null;

    if (!form || !submitButton || !toast) return;

    const showToast = (message, isError = false) => {
      toast.textContent = message;
      toast.classList.toggle("is-error", isError);
      toast.classList.add("is-show");
      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.classList.remove("is-show");
        toast.classList.remove("is-error");
      }, 1800);
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const originalText = submitButton.textContent;
      submitButton.disabled = true;
      submitButton.textContent = "保存中...";

      try {
        const formData = new FormData(form);
        formData.set("ajax", "1");
        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: {
            "X-Requested-With": "XMLHttpRequest"
          }
        });
        const result = await response.json().catch(() => ({ ok: false, message: "保存失败，请稍后再试" }));
        if (!response.ok || !result.ok) {
          showToast(result.message || "保存失败，请稍后再试", true);
          return;
        }
        if (result.user?.nickname && nameDisplay) {
          nameDisplay.textContent = result.user.nickname;
        }
        const nicknameInput = form.querySelector('input[name="nickname"]');
        if (result.user?.nickname && nicknameInput) {
          nicknameInput.value = result.user.nickname;
        }
        const avatarCurrent = form.querySelector('input[name="avatar_current"]');
        if (result.user?.avatar && avatarCurrent) {
          avatarCurrent.value = result.user.avatar;
        }
        showToast(result.message || "个人资料已保存");
      } catch (_error) {
        showToast("保存失败，请检查网络后重试", true);
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalText;
      }
    });
  })();

</script>
