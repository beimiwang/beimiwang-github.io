<%- include("./partials-shell-top", { pageTitle, token, active: 'withdraws' }) %>
<div class="admin-topbar">
  <div>
    <h1>提现审核</h1>
    <div class="meta">查看用户提现资料、收款码和申请状态，并进行通过或驳回。</div>
  </div>
</div>

<% if (msg) { %>
  <div class="notice"><%= msg %></div>
<% } %>

<div class="panel">
  <div class="panel-header">
    <h2>筛选</h2>
  </div>
  <div class="panel-body">
    <form class="toolbar" method="get" action="/admin/withdraws">
      <input class="input" type="text" name="keyword" value="<%= data.keyword %>" placeholder="搜索昵称 / 手机号 / 姓名">
      <select class="select" name="status">
        <option value="">全部状态</option>
        <option value="pending" <%= data.status === 'pending' ? 'selected' : '' %>>待审核</option>
        <option value="approved" <%= data.status === 'approved' ? 'selected' : '' %>>已通过</option>
        <option value="rejected" <%= data.status === 'rejected' ? 'selected' : '' %>>已驳回</option>
      </select>
      <button class="button primary" type="submit">查询</button>
    </form>
  </div>
</div>

<div class="panel" style="margin-top:20px;">
  <div class="panel-header">
    <h2>提现申请</h2>
    <div class="meta"><%= data.requests.length %> 条记录</div>
  </div>
  <div class="panel-body" style="display:grid;gap:16px;">
    <% data.requests.forEach((item) => { %>
      <div style="border:1px solid #edf1f5;border-radius:16px;padding:16px;">
        <div style="display:flex;justify-content:space-between;gap:16px;align-items:flex-start;">
          <div>
            <div style="font-size:20px;font-weight:700;color:#111827;"><%= item.nickname %></div>
            <div style="margin-top:6px;font-size:13px;color:#6b7280;">手机号：<%= item.phone || '未绑定' %></div>
            <div style="margin-top:4px;font-size:13px;color:#6b7280;">真实姓名：<%= item.profile_real_name || item.account_name || '未填写' %></div>
            <div style="margin-top:4px;font-size:13px;color:#6b7280;">申请时间：<%= item.created_at %></div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:22px;font-weight:800;color:#111827;">¥ <%= Number(item.amount).toFixed(2) %></div>
            <div class="badge <%= item.status === 'approved' ? 'active' : (item.status === 'rejected' ? '' : 'warn') %>" style="margin-top:8px;"><%= item.status === 'approved' ? '已通过' : (item.status === 'rejected' ? '已驳回' : '待审核') %></div>
          </div>
        </div>

        <div style="margin-top:16px;display:grid;grid-template-columns:180px 1fr;gap:16px;align-items:start;">
          <div>
            <div style="font-size:13px;font-weight:700;color:#374151;margin-bottom:8px;">微信收款码</div>
            <% if (item.wechat_qr_image || item.account_no) { %>
              <img src="<%= item.wechat_qr_image || item.account_no %>" alt="微信收款码" style="width:180px;height:180px;object-fit:cover;border-radius:12px;border:1px solid #edf1f5;background:#f8fafc;">
            <% } else { %>
              <div style="width:180px;height:180px;border-radius:12px;border:1px dashed #d8dee9;background:#f8fafc;display:flex;align-items:center;justify-content:center;color:#9ca3af;">未上传</div>
            <% } %>
          </div>
          <form method="post" action="/admin/withdraws/<%= item.id %>/status" style="display:grid;gap:10px;">
            <div style="font-size:13px;font-weight:700;color:#374151;">审核操作</div>
            <select class="select" name="status">
              <option value="pending" <%= item.status === 'pending' ? 'selected' : '' %>>待审核</option>
              <option value="approved" <%= item.status === 'approved' ? 'selected' : '' %>>通过</option>
              <option value="rejected" <%= item.status === 'rejected' ? 'selected' : '' %>>驳回</option>
            </select>
            <textarea class="input" name="review_note" placeholder="审核备注 / 驳回原因" style="min-height:92px;padding:12px;"><%= item.review_note || '' %></textarea>
            <div style="font-size:12px;color:#6b7280;">
              审核人：<%= item.reviewed_by || '-' %>
              <% if (item.reviewed_at) { %> · 审核时间：<%= item.reviewed_at %><% } %>
            </div>
            <div>
              <button class="button primary" type="submit">保存审核结果</button>
            </div>
          </form>
        </div>
      </div>
    <% }) %>

    <% if (!data.requests.length) { %>
      <div style="padding:36px 16px;text-align:center;color:#9ca3af;">暂无提现申请</div>
    <% } %>
  </div>
</div>
<%- include("./partials-shell-bottom") %>
