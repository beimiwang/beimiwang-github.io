<%- include("./partials-shell-top", { pageTitle, token, active: 'guarantee-deposits' }) %>
<div class="admin-topbar">
  <div>
    <h1>保证金审核</h1>
    <div class="meta">查看诚信保证金申请记录，审核是否通过并同步前台状态。</div>
  </div>
</div>

<% if (msg) { %>
  <div class="notice"><%= msg %></div>
<% } %>

<div class="panel">
  <div class="panel-header"><h2>筛选</h2></div>
  <div class="panel-body">
    <form class="toolbar" method="get" action="/admin/guarantee-deposits">
      <input class="input" type="text" name="keyword" value="<%= data.keyword %>" placeholder="搜索昵称 / 手机号 / 备注">
      <select class="select" name="status">
        <option value="">全部状态</option>
        <option value="unpaid" <%= data.status === 'unpaid' ? 'selected' : '' %>>未缴纳</option>
        <option value="pending" <%= data.status === 'pending' ? 'selected' : '' %>>待审核</option>
        <option value="paid" <%= data.status === 'paid' ? 'selected' : '' %>>已通过</option>
        <option value="rejected" <%= data.status === 'rejected' ? 'selected' : '' %>>已驳回</option>
      </select>
      <button class="button primary" type="submit">查询</button>
    </form>
  </div>
</div>

<div class="panel" style="margin-top:20px;">
  <div class="panel-header">
    <h2>保证金记录</h2>
    <div class="meta"><%= data.items.length %> 条记录</div>
  </div>
  <div class="panel-body" style="display:grid;gap:16px;">
    <% data.items.forEach((item) => { %>
      <div style="border:1px solid #edf1f5;border-radius:16px;padding:16px;">
        <div style="display:flex;justify-content:space-between;gap:16px;align-items:flex-start;">
          <div>
            <div style="font-size:20px;font-weight:700;color:#111827;"><%= item.nickname %></div>
            <div style="margin-top:6px;font-size:13px;color:#6b7280;">手机号：<%= item.phone || '未绑定' %></div>
            <div style="margin-top:4px;font-size:13px;color:#6b7280;">创建时间：<%= item.created_at %></div>
            <div style="margin-top:4px;font-size:13px;color:#6b7280;">更新时间：<%= item.updated_at %></div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:22px;font-weight:800;color:#111827;">¥ <%= Number(item.amount || 0).toFixed(2) %></div>
            <div class="badge <%= item.status === 'paid' ? 'active' : (item.status === 'rejected' ? '' : 'warn') %>" style="margin-top:8px;">
              <%= ({ unpaid:'未缴纳', pending:'待审核', paid:'已通过', rejected:'已驳回' }[item.status] || item.status) %>
            </div>
          </div>
        </div>

        <form method="post" action="/admin/guarantee-deposits/<%= item.id %>/status" style="margin-top:16px;display:grid;gap:10px;">
          <select class="select" name="status">
            <option value="unpaid" <%= item.status === 'unpaid' ? 'selected' : '' %>>未缴纳</option>
            <option value="pending" <%= item.status === 'pending' ? 'selected' : '' %>>待审核</option>
            <option value="paid" <%= item.status === 'paid' ? 'selected' : '' %>>通过</option>
            <option value="rejected" <%= item.status === 'rejected' ? 'selected' : '' %>>驳回</option>
          </select>
          <textarea class="input" name="note" placeholder="审核备注 / 驳回原因" style="min-height:92px;padding:12px;"><%= item.note || '' %></textarea>
          <div><button class="button primary" type="submit">保存审核结果</button></div>
        </form>
      </div>
    <% }) %>

    <% if (!data.items.length) { %>
      <div style="padding:36px 16px;text-align:center;color:#9ca3af;">暂无保证金申请</div>
    <% } %>
  </div>
</div>
<%- include("./partials-shell-bottom") %>
