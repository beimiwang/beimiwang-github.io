<%- include("./partials-shell-top", { pageTitle, token, active: 'dashboard' }) %>
<div class="admin-topbar">
  <div>
    <h1>后台概览</h1>
    <div class="meta">数据库：`data/clone.db`，用于统一管理前台页面数据。</div>
  </div>
  <div class="top-actions">
    <div class="meta">当前管理员：<code><%= token %></code></div>
    <form method="post" action="/admin/logout">
      <button class="button ghost" type="submit">退出登录</button>
    </form>
  </div>
</div>

<div class="cards">
  <div class="card"><div class="label">总帖子</div><div class="value"><%= data.overview.total_posts %></div></div>
  <div class="card"><div class="label">上架中帖子</div><div class="value"><%= data.overview.active_posts %></div></div>
  <div class="card"><div class="label">用户数</div><div class="value"><%= data.overview.total_users %></div></div>
  <div class="card"><div class="label">总浏览量</div><div class="value"><%= data.overview.total_views %></div></div>
</div>

<div class="cards">
  <div class="card"><div class="label">总点赞</div><div class="value"><%= data.overview.total_likes %></div></div>
  <div class="card"><div class="label">总分享</div><div class="value"><%= data.overview.total_shares %></div></div>
  <div class="card"><div class="label">钱包余额</div><div class="value">¥ <%= data.wallet.balance.toFixed(2) %></div></div>
  <div class="card"><div class="label">刷新套餐库存</div><div class="value"><%= data.wallet.refresh_package_count %></div></div>
</div>

<div class="panel">
  <div class="panel-header">
    <h2>最近帖子</h2>
    <a class="button ghost" href="/admin/posts">查看全部</a>
  </div>
  <div class="panel-body" style="padding-top:0;">
    <table>
      <thead>
        <tr>
          <th>编号</th>
          <th>标题</th>
          <th>作者</th>
          <th>分类</th>
          <th>状态</th>
          <th>浏览</th>
        </tr>
      </thead>
      <tbody>
        <% data.recentPosts.forEach((post) => { %>
          <tr>
            <td><%= post.id %></td>
            <td><a href="/plugin.php?id=xigua_hb&ac=view&pubid=<%= post.id %>" target="_blank"><%= post.title %></a></td>
            <td><%= post.nickname %></td>
            <td><%= post.category_name %></td>
            <td><span class="badge <%= post.status %>"><%= post.status === 'active' ? '上架中' : '已下架' %></span></td>
            <td><%= post.views %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include("./partials-shell-bottom") %>
